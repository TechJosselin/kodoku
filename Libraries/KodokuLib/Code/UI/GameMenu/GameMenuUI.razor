@using Kodoku.Lib.GameMenu
@using Kodoku.Lib.Inventory
@using Kodoku.Lib.UI.Pages
@inherits PanelComponent
@namespace Kodoku.Lib.UI
@attribute [Title( "Game Menu UI" )]
@attribute [Category( "Kodoku/UI" )]
@attribute [Icon( "menu_open" )]

<root class="@RootClass">
	<nav class="game-menu-topnav">
		@foreach ( var tab in NavTabs )
		{
			<button class="@GetNavTabClass( tab )" onclick=@( () => SetActiveTab( tab ) )>
				@GameMenuState.GetTabTitle( tab )
			</button>
		}
	</nav>

	<section class="@PageHostClass">
		@switch ( MenuState.ActiveTab )
		{
			case GameMenuTab.Inventory:
				<InventoryPage Inventory="@Inventory" Interactor="@InventoryInteractor" />
				break;
			case GameMenuTab.Stats:
				<StatsPage />
				break;
			case GameMenuTab.Map:
				<MapPage />
				break;
			case GameMenuTab.Options:
				<OptionsPage />
				break;
			default:
				<InventoryPage Inventory="@Inventory" Interactor="@InventoryInteractor" />
				break;
		}
	</section>
</root>

@code
{
	private static readonly GameMenuTab[] NavTabs =
	{
		GameMenuTab.Inventory,
		GameMenuTab.Stats,
		GameMenuTab.Map,
		GameMenuTab.Options
	};

	[Property] public bool OpenOnStart { get; set; }
	[Property] public string ToggleKey { get; set; } = "TAB";
	[Property] public string MapKey { get; set; } = "M";
	[Property] public string StatsKey { get; set; } = "I";

	private GameMenuState MenuState { get; } = new();
	private InventoryComponent Inventory { get; set; }
	private InventoryPlayerInteractionComponent InventoryInteractor { get; set; }
	private DebugMenuUI DebugMenu { get; set; }

	private string RootClass
	{
		get
		{
			var cls = MenuState.IsOpen ? "game-menu-open" : "game-menu-closed";
			if ( DebugMenu is not null && DebugMenu.IsValid() && DebugMenu.IsOpen )
				cls += " debug-overlay-active";
			return cls;
		}
	}

	private string PageHostClass => $"game-menu-page-host game-menu-page-host--{MenuState.ActiveTab.ToString().ToLowerInvariant()}";
	private string GetNavTabClass( GameMenuTab tab )
	{
		var slug = tab.ToString().ToLowerInvariant();
		var active = tab == MenuState.ActiveTab ? " active" : "";
		return $"game-menu-nav-tab game-menu-nav-tab--{slug}{active}";
	}
	public bool IsOpen => MenuState.IsOpen;

	protected override void OnStart()
	{
		ResolveInventoryReferences();

		if ( OpenOnStart )
		{
			MenuState.Open( GameMenuTab.Inventory );
		}
		else
		{
			MenuState.Close();
			MenuState.SetActiveTab( GameMenuTab.Inventory );
		}
	}

	protected override void OnUpdate()
	{
		ResolveInventoryReferences();

		if ( DebugMenu is null || !DebugMenu.IsValid() )
			DebugMenu = Scene.GetAllComponents<DebugMenuUI>().FirstOrDefault();

		HandleEscapeShortcut();

		if ( !string.IsNullOrWhiteSpace( ToggleKey ) && Input.Keyboard.Pressed( ToggleKey ) )
			ToggleTab( GameMenuTab.Inventory );

		if ( !IsBlockingUiActive() )
		{
			if ( !string.IsNullOrWhiteSpace( MapKey ) && Input.Keyboard.Pressed( MapKey ) )
				ToggleTab( GameMenuTab.Map );

			if ( !string.IsNullOrWhiteSpace( StatsKey ) && Input.Keyboard.Pressed( StatsKey ) )
				ToggleTab( GameMenuTab.Stats );
		}

		UpdateMouseVisibility();
	}

	// Escape is consumed here so s&box's own pause menu never opens on top of / instead of ours.
	// If an s&box overlay is already open (pause menu, Steam overlay, etc.), Escape is left
	// untouched so that overlay can handle it itself (e.g. closing it) instead of fighting it.
	private void HandleEscapeShortcut()
	{
		if ( !Input.EscapePressed )
			return;

		if ( IsSandboxOverlayOpen() )
			return;

		Input.EscapePressed = false;
		ToggleTab( GameMenuTab.Options );
	}

	private void ToggleTab( GameMenuTab tab )
	{
		MenuState.Toggle( tab );
		StateHasChanged();
	}

	// Guards the Map/Stats shortcuts against firing while an s&box overlay or another
	// blocking panel (debug menu) is active. Kodoku has no text-entry fields yet — once one
	// is added, extend this with a focus check (e.g. Sandbox.UI.Panel.HasFocus) so typing
	// "m" or "i" into a field doesn't also trigger these shortcuts.
	private bool IsBlockingUiActive()
	{
		if ( IsSandboxOverlayOpen() )
			return true;

		if ( DebugMenu is not null && DebugMenu.IsValid() && DebugMenu.IsOpen )
			return true;

		return false;
	}

	// Sandbox.Game.Overlay.IsOpen/IsPauseMenuOpen are instance properties even though every
	// Show*/Close method on that same type is static (confirmed via reflection against the
	// installed SDK's Sandbox.Engine.dll). There is no other public static way to query overlay
	// state, so a throwaway instance is used here. If a future SDK exposes a proper static
	// accessor, switch to it here.
	private static bool IsSandboxOverlayOpen() => new global::Sandbox.Game.Overlay().IsOpen;

	protected override void OnDisabled()
	{
		Mouse.Visibility = MouseVisibility.Auto;
		base.OnDisabled();
	}

	private void SetActiveTab( GameMenuTab tab )
	{
		MenuState.SetActiveTab( tab );
		StateHasChanged();
	}

	public void OpenInventory()
	{
		MenuState.Open( GameMenuTab.Inventory );
		UpdateMouseVisibility();
		StateHasChanged();
	}

	private void UpdateMouseVisibility()
	{
		Mouse.Visibility = MenuState.IsOpen ? MouseVisibility.Visible : MouseVisibility.Auto;
	}

	private bool ResolveInventoryReferences()
	{
		if ( Inventory is null || !Inventory.IsValid() )
			Inventory = FindPreferredInventory();

		if ( Inventory is null || !Inventory.IsValid() )
			return false;

		Inventory.EnsureInitialized();

		if ( InventoryInteractor is null || !InventoryInteractor.IsValid() )
		{
			InventoryInteractor = Scene.GetAllComponents<InventoryPlayerInteractionComponent>()
				.FirstOrDefault( candidate => candidate.Inventory == Inventory && candidate.GameObject == Inventory.GameObject );

			if ( InventoryInteractor is null || !InventoryInteractor.IsValid() )
				InventoryInteractor = Scene.GetAllComponents<InventoryPlayerInteractionComponent>()
					.FirstOrDefault( candidate => candidate.Inventory == Inventory );

			if ( InventoryInteractor is null || !InventoryInteractor.IsValid() )
				InventoryInteractor = Inventory.GameObject.Components.Get<InventoryPlayerInteractionComponent>();

			if ( InventoryInteractor is null || !InventoryInteractor.IsValid() )
				InventoryInteractor = Inventory.GameObject.Components.Create<InventoryPlayerInteractionComponent>();
		}

		if ( InventoryInteractor is null || !InventoryInteractor.IsValid() )
			return false;

		InventoryInteractor.Inventory = Inventory;

		return true;
	}

	private InventoryComponent FindPreferredInventory()
	{
		return Scene.GetAllComponents<InventoryComponent>()
			.FirstOrDefault( candidate => candidate.GameObject?.Name == "Inventory" )
			?? Scene.GetAllComponents<InventoryComponent>().FirstOrDefault();
	}

	protected override int BuildHash()
	{
		var hash = (int)MenuState.ActiveTab;
		hash = (hash * 397) ^ MenuState.IsOpen.GetHashCode();
		hash = (hash * 397) ^ OpenOnStart.GetHashCode();
		hash = (hash * 397) ^ (ToggleKey?.GetHashCode() ?? 0);
		hash = (hash * 397) ^ (MapKey?.GetHashCode() ?? 0);
		hash = (hash * 397) ^ (StatsKey?.GetHashCode() ?? 0);
		hash = (hash * 397) ^ (DebugMenu?.IsOpen == true).GetHashCode();
		return hash;
	}
}
